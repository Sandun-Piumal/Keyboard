<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Required for EmojiCompat to download the Noto Color Emoji font from Google Fonts -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SinKey">

        <!--
            Bug O2 Fix: adjustResize tells Android to shrink the activity
            window when the IME appears, so the keyboard preview FAB and
            Scaffold content are never hidden behind the keyboard.
            Without this the system picks adjustUnspecified which can overlap
            content on many devices and launchers.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SinKey.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Bug O5 Fix: Removed android:windowSoftInputMode="stateUnchanged"
            from the <service> tag. That attribute is only valid on <activity>
            elements — on a <service> it is silently ignored by Android, so it
            had no effect and was misleading dead markup.
        -->
        <service
            android:name=".ime.SinKeyInputMethodService"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SinKey.IME">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>
</manifest>
